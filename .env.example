# Email Configuration Example
# Copy this file to .env and fill in your own values for your environment

# Secret Key for Django (generate a new one for production)
# Generate new key with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Debug mode
# True = Development (uses SQLite, no database setup needed)
# False = Production (uses PostgreSQL)
DEBUG=True

# Allowed hosts (comma-separated list of domains)
# For development: localhost,127.0.0.1
# For production: example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Default: SQLite for DEBUG=True, PostgreSQL for DEBUG=False

# Option 1: Use DATABASE_URL (Cloud deployments: Heroku, Railway, Docker)
# Uncomment for production with cloud database
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Individual PostgreSQL settings (DEBUG=False only)
# Uncomment these for self-hosted production
# DB_NAME=blog_db
# DB_USER=blog_user
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSLMODE=require

# Email Backend Configuration
# Development: Use console backend (prints emails to console)
# Production: Use SMTP backend with real email service

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production with Gmail:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# For production with other SMTP providers (SendGrid, AWS SES, etc.):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=your-smtp-host.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-username
# EMAIL_HOST_PASSWORD=your-password

# Default sender email address
DEFAULT_FROM_EMAIL=noreply@blog.example.com

# Password reset link expiration time (in seconds)
# 3600 = 1 hour
PASSWORD_RESET_TIMEOUT=3600

# Optional settings (uncomment and set if needed)

# Server email (for error notifications)
# SERVER_EMAIL=server@blog.example.com

# Email subject prefix for admin emails
# EMAIL_SUBJECT_PREFIX=[Blog Alert]
